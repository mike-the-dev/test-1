# Application
APP_ENV=local
PORT=3000

# AWS_REGION — picked up automatically by all AWS SDK clients. Set to your account's region.
AWS_REGION=us-east-1

# DynamoDB
DYNAMODB_REGION=us-east-1
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_CONVERSATIONS=conversations
DYNAMODB_ACCOUNTS_DOMAIN_GSI_NAME=GSI1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# Voyage (embeddings)
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# SendGrid
SENDGRID_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PUBLIC_WEBHOOK_URL=

# Web chat CORS
WEB_CHAT_CORS_ALLOW_ALL=false
WEB_CHAT_WIDGET_ORIGINS=

# Checkout
CHECKOUT_BASE_URL_OVERRIDE=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=

# Slack
SLACK_WEBHOOK_URL=

# Internal API auth (Knowledge Base)
KB_INTERNAL_API_KEY=

# Email debounce
EMAIL_DEBOUNCE_ENABLED=false
EMAIL_DEBOUNCE_WINDOW_SECONDS=90

# Internal flush callback — must be a 32+ char secret; required at boot
INTERNAL_FLUSH_SECRET=local-dev-flush-secret-32chars-x
INTERNAL_FLUSH_URL=

# Scheduler backend: "fake" (in-memory, for local dev) or "real" (AWS EventBridge Scheduler)
SCHEDULER_BACKEND=fake
# Scheduler region: defaults to DYNAMODB_REGION if unset. Override when EventBridge resources live in a different region.
SCHEDULER_REGION=
SCHEDULER_ROLE_ARN=
# ARN of the Lambda relay function that POSTs to the internal flush endpoint with the bearer token
SCHEDULER_LAMBDA_ARN=
